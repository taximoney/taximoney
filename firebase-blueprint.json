{
  "entities": {
    "trips": {
      "title": "Trips",
      "description": "Individual taxi trip records",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the trip" },
        "amount": { "type": "number", "description": "Fare amount" },
        "tip": { "type": "number", "description": "Tip amount" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card"], "description": "Payment method" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the trip occurred" },
        "driverPercent": { "type": "number", "description": "Configured driver percentage at time of trip" }
      },
      "required": ["userId", "amount", "tip", "paymentMethod", "timestamp", "driverPercent"]
    },
    "userConfig": {
      "title": "User Configuration",
      "description": "User specific settings and preferences",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the config" },
        "driverPercent": { "type": "number", "description": "Default driver percentage" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "accumulatedDebt": { "type": "number", "description": "Accumulated debt or credit" }
      },
      "required": ["userId", "driverPercent", "lastUpdated"]
    },
    "shifts": {
      "title": "Shifts",
      "description": "Daily shift summaries",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the shift" },
        "date": { "type": "string", "description": "Date of the shift" },
        "month": { "type": "string", "description": "Month of the shift" },
        "hours": { "type": "number", "description": "Hours worked" },
        "trips": { "type": "array", "description": "List of individual trips in the shift" },
        "totals": { "type": "object", "description": "Calculated totals for the shift" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the shift was closed" }
      },
      "required": ["userId", "date", "month", "hours", "totals", "timestamp"]
    }
  },
  "firestore": {
    "/trips/{tripId}": {
      "schema": "trips",
      "description": "Collection of all taxi trips"
    },
    "/userConfigs/{userId}": {
      "schema": "userConfig",
      "description": "Individual user settings"
    },
    "/shifts/{shiftId}": {
      "schema": "shifts",
      "description": "Collection of all closed shifts"
    }
  }
}
